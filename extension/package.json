{
  "name": "browsersync-extension",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Cross-browser bookmarks/tabs/history sync.",
  "scripts": {
    "build:chrome": "node build.mjs chrome",
    "build:firefox": "node build.mjs firefox",
    "build": "npm run build:chrome && npm run build:firefox",
    "run:firefox": "web-ext run --source-dir dist/firefox",
    "test": "node --test"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "web-ext": "^8.0.0"
  }
}
