{
  "manifest_version": 3,
  "name": "BrowserSync",
  "version": "0.1.0",
  "description": "Sync bookmarks, tabs, and history across Firefox and Chromium browsers via WebDAV, a self-hosted server, or a local file.",
  "homepage_url": "https://github.com/proairface/claude-test",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["bookmarks", "tabs", "history", "storage", "unlimitedStorage", "alarms"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": { "scripts": ["background/index.js"], "type": "module" },
  "options_ui": { "page": "options/options.html", "open_in_tab": true },
  "action": {
    "default_title": "BrowserSync",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "browser_specific_settings": {
    "gecko": { "id": "browsersync@example.org", "strict_min_version": "128.0" }
  }
}
